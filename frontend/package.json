{
  "name": "urdu-translator-frontend",
  "version": "1.0.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron-start": "electron .",
    "electron-dev": "concurrently \"vite\" \"cross-env WAIT_ON=http://localhost:5173 wait-on http://localhost:5173 && electron .\""
  },
  "build": {
    "appId": "com.github.urdutranslator",
    "linux": {
      "target": ["dir"],
      "executableName": "urdu-translator-frontend"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ]
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
